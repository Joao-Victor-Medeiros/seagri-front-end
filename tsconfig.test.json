{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "types": ["jest", "node", "@testing-library/jest-dom"],
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "jestSetup.ts"]
}
